{
  "name": "htbasic",
  "displayName": "HTBasic Language Support",
  "description": "Syntax highlighting and basic syntax checking for HTBasic",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "publisher": "jsdale",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsdale/htbasic-vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],

  "activationEvents": [
    "onLanguage:htbasic"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "htbasic",
        "aliases": [
          "HTBasic",
          "htbasic"
        ],
        "extensions": [
          ".htb"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "htbasic",
        "scopeName": "source.htbasic",
        "path": "./syntaxes/htbasic.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "overrides": {
    "undici": "5.28.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0",
    "vsce": "^2.6.7"
  }
}
